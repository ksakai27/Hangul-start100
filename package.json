import { readFileSync } from "node:fs";
import { resolve } from "node:path";

function assert(condition, message) {
  if (!condition) throw new Error(message);
}

const html = readFileSync(resolve("docs/index.html"), "utf-8");
const app = readFileSync(resolve("docs/app.js"), "utf-8");

const htmlIds = new Set([...html.matchAll(/id="([^"]+)"/g)].map((match) => match[1]));
const jsIds = [...app.matchAll(/getElementById\("([^"]+)"\)/g)].map((match) => match[1]);

assert(jsIds.length > 0, "No getElementById calls found in app.js");

for (const id of jsIds) {
  assert(htmlIds.has(id), `Missing HTML id for JS selector: ${id}`);
}

const pageIds = [...html.matchAll(/<section id="([^"]+)" class="page/g)].map((match) => match[1]);
const navTargets = [...html.matchAll(/data-section-target="([^"]+)"/g)].map((match) => match[1]);

assert(new Set(pageIds).size === pageIds.length, "Page ids must be unique");
for (const target of navTargets) {
  assert(pageIds.includes(target), `Navigation target does not match a page id: ${target}`);
}

const startQuizModes = [...html.matchAll(/data-start-quiz="([^"]+)"/g)].map((match) => match[1]);
for (const mode of startQuizModes) {
  assert(["vowels", "consonants", "syllables", "audio", "phrases"].includes(mode), `Unknown quick-start quiz mode: ${mode}`);
}

console.log("Validation passed: DOM ids and section targets are in sync.");
